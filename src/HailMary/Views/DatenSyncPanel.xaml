<?xml version="1.0" encoding="utf-8" ?>

<UserControl

    x:Class="HailMary.Views.DatenSyncPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">



    <ScrollViewer HorizontalContentAlignment="Left" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

        <StackPanel Style="{StaticResource ToolShellContentPanel}" Spacing="10">

            <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" TextWrapping="WrapWholeWords" />

            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.Status, Mode=OneWay}" />



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="datensync.syncJobHeader" />

                    <Grid ColumnSpacing="8" RowSpacing="8">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="80" />

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition />

                            <RowDefinition />

                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="datensync.sourceLabel" />

                        <TextBox Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.EditorSource, Mode=TwoWay}" />

                        <Button Grid.Row="0" Grid.Column="2" Command="{x:Bind ViewModel.PickEditorSourceCommand}" loc:Loc.Key="common.addDots" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="datensync.targetLabel" />

                        <TextBox Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.EditorTarget, Mode=TwoWay}" />

                        <Button Grid.Row="1" Grid.Column="2" Command="{x:Bind ViewModel.PickEditorTargetCommand}" loc:Loc.Key="common.addDots" />

                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <Button Command="{x:Bind ViewModel.AddJobCommand}" loc:Loc.Key="datensync.addJob" />

                        <Button Command="{x:Bind ViewModel.LoadSelectedJobCommand}" loc:Loc.Key="datensync.loadSelection" />

                        <Button Command="{x:Bind ViewModel.UpdateSelectedJobCommand}" loc:Loc.Key="datensync.updateSelection" />

                        <Button Command="{x:Bind ViewModel.RemoveSelectedJobCommand}" loc:Loc.Key="datensync.removeSelection" />

                    </StackPanel>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="datensync.jobsHeader" />

                    <Grid ColumnSpacing="12" Padding="12,0,12,0">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="*" />

                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" loc:Loc.Key="datensync.sourceArrow" />

                        <TextBlock Grid.Column="1" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" loc:Loc.Key="datensync.targetArrow" />

                    </Grid>

                    <ListView x:Name="JobsList" MaxHeight="220" ItemsSource="{x:Bind ViewModel.Jobs, Mode=OneWay}" SelectionChanged="JobsList_OnSelectionChanged">

                        <ListView.ItemTemplate>

                            <DataTemplate x:DataType="viewModels:DatenSyncJobRow" xmlns:viewModels="using:HailMary.ViewModels">

                                <Grid ColumnSpacing="12">

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="Auto" />

                                        <ColumnDefinition Width="*" />

                                        <ColumnDefinition Width="Auto" />

                                        <ColumnDefinition Width="*" />

                                    </Grid.ColumnDefinitions>

                                    <FontIcon Grid.Column="0" FontSize="12" Glyph="&#xE8B7;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" loc:Loc.ToolTipKey="bitrate.colSource" />

                                    <TextBlock Grid.Column="1" FontFamily="Consolas" Text="{x:Bind Source}" TextTrimming="CharacterEllipsis" loc:Loc.ToolTipKey="bitrate.colSource" />

                                    <FontIcon Grid.Column="2" FontSize="12" Glyph="&#xE8E5;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" loc:Loc.ToolTipKey="bitrate.colTarget" />

                                    <TextBlock Grid.Column="3" FontFamily="Consolas" Text="{x:Bind Target}" TextTrimming="CharacterEllipsis" loc:Loc.ToolTipKey="bitrate.colTarget" />

                                </Grid>

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                    <TextBox loc:Loc.HeaderKey="datensync.intervalHeader" Text="{x:Bind ViewModel.IntervalMinutes, Mode=TwoWay}" />

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="datensync.robocopyOptions" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Options, Mode=OneWay}">

                        <ItemsControl.ItemTemplate>

                            <DataTemplate x:DataType="viewModels:RobocopyOptionViewModel" xmlns:viewModels="using:HailMary.ViewModels">

                                <CheckBox Content="{x:Bind Label}" IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" />

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.profile" />

                    <Grid ColumnSpacing="8">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="datensync.profileName" Text="{x:Bind ViewModel.ProfileName, Mode=TwoWay}" />

                        <ComboBox Grid.Column="1" loc:Loc.HeaderKey="datensync.loadProfile" ItemsSource="{x:Bind ViewModel.ProfileNames, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedProfileName, Mode=TwoWay}" />

                        <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Bottom">

                            <Button Command="{x:Bind ViewModel.SaveProfileCommand}" loc:Loc.Key="common.save" />

                            <Button Command="{x:Bind ViewModel.LoadProfileCommand}" loc:Loc.Key="common.load" />

                        </StackPanel>

                    </Grid>

                    <Button Command="{x:Bind ViewModel.SaveDefaultCommand}" loc:Loc.Key="datensync.saveDefault" HorizontalAlignment="Left" />

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <Button Command="{x:Bind ViewModel.StopSyncCommand}" loc:Loc.Key="common.stop" />

                    </StackPanel>

                </StackPanel>

            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>



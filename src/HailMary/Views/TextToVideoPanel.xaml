<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="HailMary.Views.TextToVideoPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HailMary.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:drop="using:HailMary.Views.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:HailMary.Models"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">

    <ScrollViewer HorizontalContentAlignment="Left" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{StaticResource ToolShellContentPanel}" Spacing="10">
            <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" TextWrapping="WrapWholeWords" />
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.Status, Mode=OneWay}" TextWrapping="WrapWholeWords" />

            <Border Style="{StaticResource ToolShellCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.video" />
                    <Grid ColumnSpacing="8" drop:VideoDrop.IsEnabled="True" drop:VideoDrop.PathPropertyName="VideoPath">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="texttovideo.videoPath" Text="{x:Bind ViewModel.VideoPath, Mode=TwoWay}" />
                        <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickVideoCommand}" loc:Loc.Key="common.addDots" />
                    </Grid>
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.VideoInfoLine, Mode=OneWay}" />
                    <controls:TextToVideoPreviewHost ViewModel="{x:Bind ViewModel, Mode=OneWay}" Visibility="{x:Bind ViewModel.HasVideo, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ToolShellCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="texttovideo.segmentsHeader" />
                    <ListView
                        x:Name="SegmentList"
                        MaxHeight="140"
                        ItemsSource="{x:Bind ViewModel.Segments, Mode=OneWay}"
                        SelectionChanged="SegmentList_OnSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:TextOverlaySegment">
                                <TextBlock Text="{x:Bind ListLabel}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.NewSegmentCommand}" loc:Loc.Key="texttovideo.newSegment" />
                        <Button Command="{x:Bind ViewModel.CommitSegmentCommand}" Content="{x:Bind ViewModel.CommitSegmentLabel, Mode=OneWay}" />
                        <Button Command="{x:Bind ViewModel.DeleteSegmentCommand}" loc:Loc.Key="common.delete" IsEnabled="{x:Bind ViewModel.IsEditingExistingSegment, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ToolShellCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" Text="{x:Bind ViewModel.SegmentEditorTitle, Mode=OneWay}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            AcceptsReturn="True"
                            loc:Loc.HeaderKey="texttovideo.textHeader"
                            MaxHeight="120"
                            Text="{x:Bind ViewModel.EditorSegment.Text, Mode=TwoWay}"
                            TextWrapping="Wrap" />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Command="{x:Bind ViewModel.PasteTextCommand}"
                            loc:Loc.Key="common.insert" />
                    </Grid>
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="texttovideo.stylePresets" />
                        <StackPanel x:Name="StylePresetPanel" Orientation="Horizontal" Spacing="8" />
                    </StackPanel>
                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.fontSize" />
                        <NumberBox Grid.Row="0" Grid.Column="1" Maximum="200" Minimum="12" Value="{x:Bind ViewModel.EditorSegment.Fontsize, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.color" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.EditorSegment.Color, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.position" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <NumberBox Width="100" Maximum="20000" Minimum="0" Value="{x:Bind ViewModel.EditorSegment.PosX, Mode=TwoWay}" />
                            <NumberBox Width="100" Maximum="20000" Minimum="0" Value="{x:Bind ViewModel.EditorSegment.PosY, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.lineSpacing" />
                        <NumberBox Grid.Row="3" Grid.Column="1" Maximum="120" Minimum="-120" Value="{x:Bind ViewModel.EditorSegment.LineSpacing, Mode=TwoWay}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Top" loc:Loc.Key="texttovideo.timeFromTo" />
                        <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <StackPanel MinWidth="140" Spacing="2">
                                    <TextBox loc:Loc.PlaceholderKey="texttovideo.timePlaceholder" Text="{x:Bind ViewModel.EditorSegment.From, Mode=TwoWay}" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind ViewModel.EditorFromTimeHint, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <Button VerticalAlignment="Top" Click="InsertFrom_Click" loc:Loc.Key="texttovideo.insertFrom" loc:Loc.ToolTipKey="texttovideo.insertFromTooltip" />
                                <StackPanel MinWidth="140" Spacing="2">
                                    <TextBox loc:Loc.PlaceholderKey="texttovideo.timePlaceholder" Text="{x:Bind ViewModel.EditorSegment.To, Mode=TwoWay}" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind ViewModel.EditorToTimeHint, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <Button VerticalAlignment="Top" Click="InsertTo_Click" loc:Loc.Key="texttovideo.insertTo" loc:Loc.ToolTipKey="texttovideo.insertToTooltip" />
                            </StackPanel>
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                loc:Loc.Key="texttovideo.timeFormatHint"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.fontFile" />
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.EditorSegment.FontPath, Mode=TwoWay}" />
                        <Button Grid.Row="5" Grid.Column="2" Command="{x:Bind ViewModel.PickFontCommand}" loc:Loc.Key="common.addDots" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox loc:Loc.Key="common.bold" IsChecked="{x:Bind ViewModel.EditorSegment.Bold, Mode=TwoWay}" />
                        <CheckBox loc:Loc.Key="common.italic" IsChecked="{x:Bind ViewModel.EditorSegment.Italic, Mode=TwoWay}" />
                        <CheckBox loc:Loc.Key="common.strike" IsChecked="{x:Bind ViewModel.EditorSegment.Strike, Mode=TwoWay}" />
                        <CheckBox loc:Loc.Key="texttovideo.textBackground" IsChecked="{x:Bind ViewModel.EditorSegment.BoxEnabled, Mode=TwoWay}" />
                    </StackPanel>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.italicFont" />
                        <TextBox Grid.Column="1" Text="{x:Bind ViewModel.EditorSegment.ItalicFontPath, Mode=TwoWay}" />
                        <Button Grid.Column="2" Command="{x:Bind ViewModel.PickItalicFontCommand}" loc:Loc.Key="common.addDots" />
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.padding" />
                        <NumberBox Grid.Column="1" Maximum="40" Minimum="0" Value="{x:Bind ViewModel.EditorSegment.BoxBorder, Mode=TwoWay}" />
                    </Grid>
                    <StackPanel x:Name="ColorPalettePanel" Orientation="Horizontal" Spacing="6" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ToolShellCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="texttovideo.subtitlesOptional" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="texttovideo.srtPath" Text="{x:Bind ViewModel.SrtPath, Mode=TwoWay}" />
                        <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickSrtCommand}" loc:Loc.Key="texttovideo.srtPick" />
                        <Button Grid.Column="2" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.ClearSrtCommand}" loc:Loc.Key="common.remove" />
                    </Grid>
                    <Button Command="{x:Bind ViewModel.ImportSrtToSegmentsCommand}" loc:Loc.Key="texttovideo.importSrt" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ToolShellCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="texttovideo.batchHeader" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.PickBatchVideosCommand}" loc:Loc.Key="texttovideo.batchVideos" />
                        <Button Command="{x:Bind ViewModel.ScanBatchFolderCommand}" loc:Loc.Key="bitrate.scanFolder" />
                        <Button Command="{x:Bind ViewModel.RemoveSelectedBatchRowsCommand}" loc:Loc.Key="datensync.removeSelection" />
                        <Button Command="{x:Bind ViewModel.ClearBatchCommand}" loc:Loc.Key="common.clearList" />
                    </StackPanel>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="texttovideo.batchOutputDir" Text="{x:Bind ViewModel.BatchOutputDir, Mode=TwoWay}" />
                        <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickBatchOutputDirCommand}" loc:Loc.Key="common.folder" />
                    </Grid>
                    <ListView MaxHeight="160" ItemsSource="{x:Bind ViewModel.BatchRows, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:TextToVideoBatchRow">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind Status}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Command="{x:Bind ViewModel.ExportBatchCommand}" Content="{x:Bind ViewModel.BatchExportLabel, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ToolShellCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.export" />
                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="common.container" />
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{x:Bind ViewModel.ContainerChoices, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.ExportContainer, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="common.codec" />
                        <ComboBox Grid.Row="1" Grid.Column="1" IsEnabled="{x:Bind ViewModel.IsMp4Export, Mode=OneWay}" ItemsSource="{x:Bind ViewModel.CodecChoices, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.Codec, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="common.bitrate" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <TextBox Width="120" IsEnabled="{x:Bind ViewModel.IsMp4Export, Mode=OneWay}" Text="{x:Bind ViewModel.Bitrate, Mode=TwoWay}" />
                            <Button Command="{x:Bind ViewModel.ApplySourceBitrateCommand}" loc:Loc.Key="bitrate.colSource" IsEnabled="{x:Bind ViewModel.IsMp4Export, Mode=OneWay}" />
                        </StackPanel>
                        <CheckBox Grid.Row="3" Grid.Column="1" loc:Loc.Key="texttovideo.audioCopyMp4" IsChecked="{x:Bind ViewModel.AudioCopy, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.IsMp4Export, Mode=OneWay}" />
                    </Grid>
                    <Grid ColumnSpacing="8" RowSpacing="8" Visibility="{x:Bind ViewModel.IsGifExport, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" loc:Loc.Key="texttovideo.gifFps" />
                        <NumberBox Grid.Row="0" Grid.Column="1" Maximum="60" Minimum="1" Value="{x:Bind ViewModel.GifFps, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" loc:Loc.Key="texttovideo.gifMaxWidth" />
                        <NumberBox Grid.Row="1" Grid.Column="1" Maximum="1920" Minimum="160" Value="{x:Bind ViewModel.GifMaxWidth, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" loc:Loc.Key="texttovideo.paletteColors" />
                        <NumberBox Grid.Row="2" Grid.Column="1" Maximum="256" Minimum="8" Value="{x:Bind ViewModel.GifPaletteColors, Mode=TwoWay}" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.ExportCommand}" loc:Loc.Key="texttovideo.exportFfmpeg" Style="{StaticResource AccentButtonStyle}" />
                        <Button Command="{x:Bind ViewModel.SaveSettingsCommand}" loc:Loc.Key="common.save" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ToolShellCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="texttovideo.davinciSection" />
                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        loc:Loc.Key="texttovideo.davinciHint"
                        TextWrapping="WrapWholeWords" />
                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.renderPreset" />
                        <TextBox Grid.Row="0" Grid.Column="1" PlaceholderText="YouTube - 1080p" Text="{x:Bind ViewModel.DavinciPreset, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="texttovideo.outputDir" />
                        <Grid Grid.Row="1" Grid.Column="1" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" loc:Loc.PlaceholderKey="texttovideo.outputDirDefault" Text="{x:Bind ViewModel.DavinciOutputDir, Mode=TwoWay}" />
                            <Button Grid.Column="1" Command="{x:Bind ViewModel.PickDavinciOutputDirCommand}" loc:Loc.Key="common.folder" />
                        </Grid>
                    </Grid>
                    <CheckBox
                        loc:Loc.Key="texttovideo.useLastFfmpeg"
                        IsChecked="{x:Bind ViewModel.UseLastFfmpegForResolve, Mode=TwoWay}"
                        IsEnabled="{x:Bind ViewModel.HasLastFfmpegOutput, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.LastFfmpegOutput, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <Button Command="{x:Bind ViewModel.ExportResolveCommand}" loc:Loc.Key="texttovideo.exportResolve" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

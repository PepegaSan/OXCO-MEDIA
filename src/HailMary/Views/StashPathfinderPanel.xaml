<?xml version="1.0" encoding="utf-8" ?>

<UserControl

    x:Class="HailMary.Views.StashPathfinderPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    HorizontalAlignment="Left"

    VerticalAlignment="Top"

    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">



    <ScrollViewer HorizontalContentAlignment="Left" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

        <StackPanel MaxWidth="720" Padding="16,12" HorizontalAlignment="Left" Spacing="10">

            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="stashpathfinder.searchHeader" />

                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.ConnectionInfo, Mode=OneWay}" />



                    <Grid ColumnSpacing="8">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="common.searchScene" KeyDown="SearchBox_OnKeyDown" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />

                        <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.SearchCommand}" loc:Loc.Key="common.search" />

                    </Grid>



                    <Grid ColumnSpacing="8">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                            <ColumnDefinition Width="Auto" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="common.sceneId" KeyDown="SceneIdBox_OnKeyDown" Text="{x:Bind ViewModel.SceneId, Mode=TwoWay}" />

                        <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.LoadSceneCommand}" loc:Loc.Key="common.load" />

                        <Button

                            Grid.Column="2"

                            VerticalAlignment="Bottom"

                            Command="{x:Bind ViewModel.LoadFromSessionCommand}"

                            loc:Loc.Key="common.lastScene"

                            loc:Loc.ToolTipKey="stash.lastSceneTooltip" />

                        <Button Grid.Column="3" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.LoadFromClipboardCommand}" loc:Loc.Key="common.clipboard" />

                    </Grid>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.results" />

                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="stash.resultsHint" />

                    <ListView

                        x:Name="ResultsList"

                        MinHeight="160"

                        MaxHeight="280"

                        DoubleTapped="ResultsList_OnDoubleTapped"

                        ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"

                        SelectionChanged="ResultsList_OnSelectionChanged">

                        <ListView.ItemTemplate>

                            <DataTemplate x:DataType="viewModels:StashSceneRowViewModel" xmlns:viewModels="using:HailMary.ViewModels">

                                <TextBlock FontFamily="Consolas" Text="{x:Bind Display}" TextTrimming="CharacterEllipsis" />

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.paths" />

                    <Button Command="{x:Bind ViewModel.ReloadLoadedCommand}" loc:Loc.Key="stash.reloadLoaded" HorizontalAlignment="Left" />

                    <TextBlock FontFamily="Consolas" Text="{x:Bind ViewModel.LoadedSummary, Mode=OneWay}" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <Button Command="{x:Bind ViewModel.CopyFolderPathCommand}" loc:Loc.Key="common.copyFolder" />

                        <Button Command="{x:Bind ViewModel.CopyFilenameCommand}" loc:Loc.Key="common.copyFilename" />

                        <Button Command="{x:Bind ViewModel.CopyFullPathCommand}" loc:Loc.Key="common.copyFullPath" />

                        <Button Command="{x:Bind ViewModel.OpenExplorerCommand}" loc:Loc.Key="common.explorer" />

                        <Button Command="{x:Bind ViewModel.OpenInStashCommand}" loc:Loc.Key="common.inStash" />

                    </StackPanel>

                </StackPanel>

            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>



<?xml version="1.0" encoding="utf-8" ?>

<UserControl

    x:Class="HailMary.Views.MarkerAutocutPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    xmlns:viewModels="using:HailMary.ViewModels"

    HorizontalAlignment="Left"

    VerticalAlignment="Top"

    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">



    <Grid HorizontalAlignment="Left" MaxWidth="1200" Padding="16,12" ColumnSpacing="10" VerticalAlignment="Top">

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="2*" MinWidth="280" />

            <ColumnDefinition Width="1.2*" MinWidth="220" />

            <ColumnDefinition Width="1.4*" MinWidth="240" />

        </Grid.ColumnDefinitions>



        <!-- Marker-Liste -->

        <Border Grid.Column="0" Style="{StaticResource ToolShellCard}" VerticalAlignment="Stretch">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="markerautocut.markersHeader" />

                    <TextBox loc:Loc.HeaderKey="markerautocut.nameFilter" Text="{x:Bind ViewModel.NameFilter, Mode=TwoWay}" />

                    <TextBox loc:Loc.HeaderKey="markerautocut.nameExclude" Text="{x:Bind ViewModel.NameExclude, Mode=TwoWay}" />

                    <TextBox loc:Loc.HeaderKey="markerautocut.pathFilter" Text="{x:Bind ViewModel.PathFilter, Mode=TwoWay}" />

                    <TextBox loc:Loc.HeaderKey="markerautocut.pathExclude" Text="{x:Bind ViewModel.PathExclude, Mode=TwoWay}" />

                    <TextBox loc:Loc.HeaderKey="markerautocut.mediaRoot" Text="{x:Bind ViewModel.MediaRoot, Mode=TwoWay}" />

                    <CheckBox loc:Loc.Key="stash.useBackup" IsChecked="{x:Bind ViewModel.UseBackup, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.BackupToggleEnabled, Mode=OneWay}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <Button Command="{x:Bind ViewModel.FetchMarkersCommand}" loc:Loc.Key="markerautocut.fetchMarkers" />

                        <Button Command="{x:Bind ViewModel.SelectAllMarkersCommand}" loc:Loc.Key="common.all" />

                        <Button Command="{x:Bind ViewModel.ClearMarkerSelectionCommand}" loc:Loc.Key="common.none" />

                        <Button Command="{x:Bind ViewModel.CyclePathSortCommand}" Content="{x:Bind ViewModel.PathSortLabel, Mode=OneWay}" />

                    </StackPanel>

                    <ListView ItemsSource="{x:Bind ViewModel.DisplayItems, Mode=OneWay}" SelectionMode="None">

                        <ListView.ItemTemplate>

                            <DataTemplate x:DataType="viewModels:MarkerAutocutDisplayItem">

                                <StackPanel Spacing="2">

                                    <TextBlock

                                        FontWeight="SemiBold"

                                        FontFamily="Segoe UI"

                                        Text="{x:Bind HeaderText}"

                                        TextWrapping="Wrap"

                                        Visibility="{x:Bind IsFileHeader, Converter={StaticResource BoolToVisibility}}" />

                                    <CheckBox

                                        Margin="12,0,0,0"

                                        Content="{x:Bind Marker.GroupedDisplay}"

                                        IsChecked="{x:Bind Marker.IsSelected, Mode=TwoWay}"

                                        Visibility="{x:Bind IsFileHeader, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}" />

                                </StackPanel>

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                </StackPanel>

            </ScrollViewer>

        </Border>



        <!-- Export-Reihenfolge -->

        <Border Grid.Column="1" Style="{StaticResource ToolShellCard}" VerticalAlignment="Stretch">

            <Grid RowSpacing="8">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="*" MinHeight="120" />

                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="markerautocut.exportOrderHeader" />

                <TextBlock

                    Grid.Row="1"

                    Style="{StaticResource CaptionTextBlockStyle}"

                    loc:Loc.Key="markerautocut.exportOrderHint"

                    TextWrapping="WrapWholeWords" />

                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6">

                    <Button Command="{x:Bind ViewModel.MoveOrderTopCommand}" Content="▲▲" loc:Loc.ToolTipKey="markerautocut.moveTopTooltip" />

                    <Button Command="{x:Bind ViewModel.MoveOrderUpCommand}" Content="▲" loc:Loc.ToolTipKey="dlsort.moveUpTooltip" />

                    <Button Command="{x:Bind ViewModel.MoveOrderDownCommand}" Content="▼" loc:Loc.ToolTipKey="dlsort.moveDownTooltip" />

                    <Button Command="{x:Bind ViewModel.MoveOrderBottomCommand}" Content="▼▼" loc:Loc.ToolTipKey="markerautocut.moveBottomTooltip" />

                    <Button Command="{x:Bind ViewModel.RemoveFromExportOrderCommand}" loc:Loc.Key="common.remove" />

                    <Button Command="{x:Bind ViewModel.SyncExportOrderCommand}" loc:Loc.Key="common.sync" loc:Loc.ToolTipKey="markerautocut.syncTooltip" />

                </StackPanel>

                <ListView

                    x:Name="OrderList"

                    Grid.Row="3"

                    AllowDrop="True"

                    CanReorderItems="True"

                    DragItemsCompleted="OrderList_DragItemsCompleted"

                    ItemsSource="{x:Bind ViewModel.ExportOrder, Mode=OneWay}"

                    SelectionChanged="OrderList_OnSelectionChanged"

                    SelectionMode="Extended">

                    <ListView.ItemTemplate>

                        <DataTemplate x:DataType="viewModels:MarkerAutocutOrderRowViewModel">

                            <StackPanel Spacing="2">

                                <TextBlock

                                    FontWeight="SemiBold"

                                    Text="{x:Bind GroupHeader, Mode=OneWay}"

                                    TextTrimming="CharacterEllipsis"

                                    Visibility="{x:Bind ShowGroupHeader, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                                <TextBlock FontFamily="Consolas" FontSize="12" Text="{x:Bind Display}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />

                            </StackPanel>

                        </DataTemplate>

                    </ListView.ItemTemplate>

                </ListView>

            </Grid>

        </Border>



        <!-- Resolve-Export -->

        <Border Grid.Column="2" Style="{StaticResource ToolShellCard}" VerticalAlignment="Stretch">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="markerautocut.resolveExportHeader" />

                    <ComboBox loc:Loc.HeaderKey="clipjoiner.modeLabel" ItemsSource="{x:Bind ViewModel.ModeChoices, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.ExportMode, Mode=TwoWay}" />

                    <Grid ColumnSpacing="8">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="markerautocut.outputDir" Text="{x:Bind ViewModel.OutputDir, Mode=TwoWay}" />

                        <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickOutputDirCommand}" loc:Loc.Key="common.addDots" />

                    </Grid>

                    <TextBox loc:Loc.HeaderKey="markerautocut.renderPreset" Text="{x:Bind ViewModel.RenderPreset, Mode=TwoWay}" />

                    <NumberBox loc:Loc.HeaderKey="markerautocut.minSegment" Value="{x:Bind ViewModel.MinSegmentSeconds, Mode=TwoWay}" />

                    <NumberBox loc:Loc.HeaderKey="markerautocut.defaultFps" Value="{x:Bind ViewModel.DefaultFps, Mode=TwoWay}" />

                    <CheckBox loc:Loc.Key="markerautocut.inclusiveEnd" IsChecked="{x:Bind ViewModel.InclusiveEnd, Mode=TwoWay}" />

                    <CheckBox loc:Loc.Key="markerautocut.doRender" IsChecked="{x:Bind ViewModel.DoRender, Mode=TwoWay}" />

                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.Status, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>

</UserControl>



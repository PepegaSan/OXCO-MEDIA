<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="HailMary.Views.Controls.IntroVideoPreviewHost"
    x:Name="RootHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:drop="using:HailMary.Views.Helpers"
    xmlns:controls="using:HailMary.Views.Controls"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">

    <StackPanel HorizontalAlignment="Left" Spacing="8" drop:VideoDrop.AllowFolders="True" drop:VideoDrop.IsEnabled="True">
        <controls:AspectFitVideoPresenter
            x:Name="VideoSurface"
            MaxPreviewHeight="480"
            MinPreviewHeight="120" />

        <StackPanel Spacing="6">
            <Slider
                x:Name="TimelineSlider"
                IsEnabled="{x:Bind ViewModel.HasVideo, Mode=OneWay}"
                Maximum="{x:Bind ViewModel.SliderMaximum, Mode=OneWay}"
                Value="{x:Bind ViewModel.SliderValue, Mode=TwoWay}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontFamily="Consolas" Text="{x:Bind ViewModel.PositionDisplay, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.CutSummary, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    FontFamily="Consolas"
                    Text="{x:Bind ViewModel.DurationDisplay, Mode=OneWay}" />
            </Grid>
        </StackPanel>

        <Grid x:Name="CutBarGrid" ColumnSpacing="4" Height="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#C44E52" CornerRadius="4,0,0,4">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="White" Text="{x:Bind ViewModel.IntroBarLabel, Mode=OneWay}" />
            </Border>
            <Border Grid.Column="1" Background="#3A8F5C">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="White" Text="{x:Bind ViewModel.MainBarLabel, Mode=OneWay}" />
            </Border>
            <Border Grid.Column="2" Background="#C44E52" CornerRadius="0,4,4,0">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="White" Text="{x:Bind ViewModel.OutroBarLabel, Mode=OneWay}" />
            </Border>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Click="BtnPlay_Click" loc:Loc.Key="common.play" IsEnabled="{x:Bind ViewModel.HasVideo, Mode=OneWay}" />
            <Button Click="BtnPause_Click" loc:Loc.Key="common.pause" IsEnabled="{x:Bind ViewModel.HasVideo, Mode=OneWay}" />
            <Button Command="{x:Bind ViewModel.SeekToIntroEndCommand}" loc:Loc.Key="intro.seekIntroEnd" IsEnabled="{x:Bind ViewModel.HasVideo, Mode=OneWay}" />
            <Button Command="{x:Bind ViewModel.SeekToOutroStartCommand}" loc:Loc.Key="intro.seekOutroStart" IsEnabled="{x:Bind ViewModel.HasVideo, Mode=OneWay}" />
        </StackPanel>
    </StackPanel>
</UserControl>

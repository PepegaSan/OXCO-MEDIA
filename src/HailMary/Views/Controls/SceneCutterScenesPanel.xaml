<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="HailMary.Views.Controls.SceneCutterScenesPanel"
    x:Name="RootPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:HailMary.Models"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">

    <Grid
        Padding="16,12"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Top"
        RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" MinHeight="120" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Left" Orientation="Horizontal" Spacing="8">
            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="cutter.scenesHeader" VerticalAlignment="Center" />
            <Button Command="{x:Bind ViewModel.TogglePartialSelectModeCommand}" Content="{x:Bind ViewModel.PartialSelectButtonText, Mode=OneWay}" />
            <CheckBox loc:Loc.Key="cutter.chronologicalSort" IsChecked="{x:Bind ViewModel.ChronologicalSort, Mode=TwoWay}" />
            <Button Command="{x:Bind ViewModel.ClearScenesCommand}" loc:Loc.Key="cutter.clearScenes" />
        </StackPanel>

        <Grid
            Grid.Row="1"
            HorizontalAlignment="Left"
            Padding="4,0"
            ColumnSpacing="8"
            Visibility="{x:Bind ViewModel.ShowSceneCheckboxes, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="36" />
                <ColumnDefinition Width="52" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource CaptionTextBlockStyle}" Text="✓" />
            <TextBlock Grid.Column="1" Style="{StaticResource CaptionTextBlockStyle}" Text="#" />
            <TextBlock Grid.Column="2" Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="common.position" />
            <TextBlock Grid.Column="3" Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="actionBar.start" />
            <TextBlock Grid.Column="4" Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="common.end" />
            <TextBlock Grid.Column="5" Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="common.order" />
        </Grid>

        <ListView
            Grid.Row="2"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ItemsSource="{x:Bind ViewModel.Scenes, Mode=OneWay}"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollMode="Disabled"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="Padding" Value="0,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SceneEntry">
                    <Grid HorizontalAlignment="Left" ColumnSpacing="6" Padding="2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            Grid.Column="0"
                            IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                            IsEnabled="{Binding ElementName=RootPanel, Path=ViewModel.ShowSceneCheckboxes}" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" Text="{x:Bind Number}" />
                        <TextBox
                            Grid.Column="2"
                            FontFamily="Consolas"
                            KeyDown="ScenePosition_KeyDown"
                            PlaceholderText="#"
                            Tag="{x:Bind}"
                            Text="{x:Bind PositionInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Grid.Column="3"
                            FontFamily="Consolas"
                            LostFocus="SceneTime_LostFocus"
                            loc:Loc.PlaceholderKey="actionBar.start"
                            Tag="{x:Bind}"
                            Text="{x:Bind StartInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Grid.Column="4"
                            FontFamily="Consolas"
                            LostFocus="SceneTime_LostFocus"
                            loc:Loc.PlaceholderKey="common.end"
                            Tag="{x:Bind}"
                            Text="{x:Bind EndInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="2">
                            <Button Click="MoveSceneUp_Click" Content="↑" Tag="{x:Bind}" />
                            <Button Click="MoveSceneDown_Click" Content="↓" Tag="{x:Bind}" />
                        </StackPanel>
                        <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="4">
                            <Button Click="SeekScene_Click" Content="▶" Tag="{x:Bind}" />
                            <Button Click="RemoveScene_Click" Content="×" Tag="{x:Bind}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" HorizontalAlignment="Left" Spacing="8">
            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.export" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <CheckBox loc:Loc.Key="cutter.safeOutput" IsChecked="{x:Bind ViewModel.SafeOutput, Mode=TwoWay}" />
                <CheckBox loc:Loc.Key="cutter.autoRemoveExported" IsChecked="{x:Bind ViewModel.AutoRemoveExported, Mode=TwoWay}" />
                <CheckBox loc:Loc.Key="cutter.useDavinciExport" IsChecked="{x:Bind ViewModel.UseDavinciExport, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{x:Bind ViewModel.UseDavinciExport, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                <ComboBox
                    Width="180"
                    ItemsSource="{x:Bind ViewModel.CodecOptions, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedCodec, Mode=TwoWay}" />
                <TextBox
                    Width="280"
                    loc:Loc.HeaderKey="cutter.ffmpegOutputDir"
                    loc:Loc.PlaceholderKey="cutter.ffmpegOutputDirPlaceholder"
                    Text="{x:Bind ViewModel.FfmpegOutputDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <Grid ColumnSpacing="12" Visibility="{x:Bind ViewModel.UseDavinciExport, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="cutter.resolvePreset" />
                <TextBox Grid.Column="1" Text="{x:Bind ViewModel.DavinciPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" loc:Loc.Key="cutter.davinciOutputDir" />
                <TextBox Grid.Column="3" Text="{x:Bind ViewModel.DavinciOutputDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>

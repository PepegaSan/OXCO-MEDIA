<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="HailMary.Views.DlSortPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:HailMary.ViewModels"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">

    <TabView
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        IsAddTabButtonVisible="False"
        TabWidthMode="SizeToContent">
        <TabViewItem Header="Profile" IsClosable="False">
            <ScrollViewer HorizontalContentAlignment="Left" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Style="{StaticResource ToolShellContentPanel}" Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="dlsort.profileHintFull" TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.Status, Mode=OneWay}" />

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{x:Bind ViewModel.AddProfileCommand}" loc:Loc.Key="dlsort.addProfile" />
                                <Button Command="{x:Bind ViewModel.RemoveSelectedProfileCommand}" loc:Loc.Key="dlsort.removeProfile" />
                                <Button Command="{x:Bind ViewModel.SaveConfigCommand}" loc:Loc.Key="common.save" />
                            </StackPanel>
                            <ListView
                                x:Name="ProfilesList"
                                MinHeight="120"
                                MaxHeight="200"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                                SelectionChanged="ProfilesList_OnSelectionChanged">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:DlSortProfileRow">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <CheckBox loc:Loc.Key="common.active" IsChecked="{x:Bind RunEnabled, Mode=TwoWay}" />
                                            <TextBlock VerticalAlignment="Center" Text="{x:Bind Name}" />
                                            <TextBlock VerticalAlignment="Center" FontFamily="Consolas" Opacity="0.7" Text="{x:Bind WatchFolder}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="dlsort.selectedProfile" />
                            <TextBox loc:Loc.HeaderKey="datensync.profileName" Text="{x:Bind ViewModel.EditorName, Mode=TwoWay}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="dlsort.watchFolder" Text="{x:Bind ViewModel.EditorWatchFolder, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickWatchFolderCommand}" loc:Loc.Key="common.addDots" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{x:Bind ViewModel.StopMonitorCommand}" loc:Loc.Key="dlsort.stopMonitor" />
                                <Button Command="{x:Bind ViewModel.ScanCommand}" loc:Loc.Key="bitrate.scanFolder" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabViewItem>

        <TabViewItem loc:Loc.HeaderKey="common.rules" IsClosable="False">
            <Grid HorizontalAlignment="Left" MaxWidth="960" Padding="16,12" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ToolShellCard}">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="dlsort.rulesForProfile" />
                            <ComboBox
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="Name"
                                ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}" />
                        </Grid>
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            loc:Loc.Key="dlsort.rulesHintFull"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{x:Bind ViewModel.AddRuleCommand}" loc:Loc.Key="dlsort.addRule" Style="{StaticResource AccentButtonStyle}" />
                            <Button Command="{x:Bind ViewModel.RemoveLastRuleCommand}" loc:Loc.Key="dlsort.removeLastRule" />
                            <Button Command="{x:Bind ViewModel.SaveConfigCommand}" loc:Loc.Key="common.save" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.CurrentRules, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:DlSortRuleRow">
                            <Border
                                Margin="0,0,0,10"
                                Padding="12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Title, Mode=OneWay}" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button
                                                Width="36"
                                                Command="{x:Bind MoveUpCommand}"
                                                Content="↑"
                                                IsEnabled="{x:Bind CanMoveUp, Mode=OneWay}"
                                                loc:Loc.ToolTipKey="dlsort.moveUpTooltip" />
                                            <Button
                                                Width="36"
                                                Command="{x:Bind MoveDownCommand}"
                                                Content="↓"
                                                IsEnabled="{x:Bind CanMoveDown, Mode=OneWay}"
                                                loc:Loc.ToolTipKey="dlsort.moveDownTooltip" />
                                            <Button
                                                Command="{x:Bind RemoveRuleCommand}"
                                                Content="✕"
                                                loc:Loc.ToolTipKey="dlsort.removeRuleTooltip" />
                                        </StackPanel>
                                    </Grid>

                                    <ItemsControl ItemsSource="{x:Bind Criteria, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="viewModels:DlSortCriterionRow">
                                                <StackPanel Margin="0,0,0,4" Spacing="3">
                                                    <Grid ColumnSpacing="6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="48" />
                                                            <ColumnDefinition Width="148" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind Prefix, Mode=OneWay}" />
                                                        <ComboBox
                                                            Grid.Column="1"
                                                            HorizontalAlignment="Stretch"
                                                            ItemsSource="{x:Bind IfLabels}"
                                                            SelectedItem="{x:Bind IfTypeLabel, Mode=TwoWay}" />
                                                        <ComboBox
                                                            Grid.Column="2"
                                                            HorizontalAlignment="Stretch"
                                                            ItemsSource="{x:Bind ConditionLabels}"
                                                            SelectedItem="{x:Bind ConditionLabel, Mode=TwoWay}" />
                                                        <TextBox
                                                            Grid.Column="3"
                                                            loc:Loc.PlaceholderKey="dlsort.criterionExample"
                                                            Text="{x:Bind FirstValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <Button
                                                            Grid.Column="4"
                                                            Command="{x:Bind AddOrValueCommand}"
                                                            loc:Loc.Key="dlsort.addOr" />
                                                        <Button
                                                            Grid.Column="5"
                                                            Command="{x:Bind RemoveCriterionCommand}"
                                                            Content="✕"
                                                            loc:Loc.ToolTipKey="dlsort.removeCriterionTooltip"
                                                            Visibility="{x:Bind CanRemove, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                                    </Grid>
                                                    <ItemsControl ItemsSource="{x:Bind OrValues, Mode=OneWay}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="viewModels:DlSortOrValueRow">
                                                                <Grid Margin="0,2,0,0" ColumnSpacing="6">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="48" />
                                                                        <ColumnDefinition Width="148" />
                                                                        <ColumnDefinition Width="120" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock
                                                                        Grid.Column="0"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                        loc:Loc.Key="dlsort.orLabel" />
                                                                    <TextBox
                                                                        Grid.Column="3"
                                                                        loc:Loc.PlaceholderKey="dlsort.criterionAlt"
                                                                        Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                    <Button
                                                                        Grid.Column="4"
                                                                        Command="{x:Bind RemoveCommand}"
                                                                        Content="✕" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button
                                        HorizontalAlignment="Left"
                                        Command="{x:Bind AddCriterionCommand}"
                                        loc:Loc.Key="dlsort.addAnd" />

                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            loc:Loc.Key="dlsort.thenLabel" />
                                        <ComboBox
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{x:Bind ActionLabels}"
                                            SelectedItem="{x:Bind ActionLabel, Mode=TwoWay}" />
                                        <Button
                                            Grid.Column="2"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Command="{x:Bind PickTargetCommand}"
                                            Content="{x:Bind TargetButtonText, Mode=OneWay}"
                                            Visibility="{x:Bind ShowTarget, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </TabViewItem>
    </TabView>
</UserControl>

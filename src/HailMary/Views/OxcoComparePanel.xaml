<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="HailMary.Views.OxcoComparePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:HailMary.ViewModels"
    xmlns:controls="using:HailMary.Views.Controls"
    xmlns:drop="using:HailMary.Views.Helpers"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">

    <UserControl.Resources>
        <ResourceDictionary>
        <Style x:Key="OxcoCompareListItemStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
        </Style>

        <Style x:Key="OxcoCompareDeepfakeListItemStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ListViewItemPresenter
                            HorizontalContentAlignment="Stretch"
                            Content="{TemplateBinding Content}"
                            ContentTransitions="{TemplateBinding ContentTransitions}"
                            CheckMode="Inline"
                            CheckBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            SelectionCheckMarkVisualEnabled="True"
                            SelectedBackground="Transparent"
                            SelectedBorderThickness="0"
                            PointerOverBackground="{ThemeResource SubtleFillColorSecondaryBrush}"
                            PressedBackground="{ThemeResource SubtleFillColorTertiaryBrush}"
                            Padding="2,1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="OxcoCompareRowTemplate" x:DataType="viewModels:OxcoCompareDisplayItem">
            <StackPanel Spacing="2">
                <Border
                    Padding="6,4"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="4"
                    Visibility="{x:Bind IsGroupHeader, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind GroupLabel}" />
                </Border>
                <Border
                    Padding="6,4"
                    Background="{x:Bind BackgroundColor, Converter={StaticResource HexToBrush}, Mode=OneTime}"
                    BorderBrush="{x:Bind RowBorderColor, Converter={StaticResource HexToBrush}, Mode=OneWay}"
                    BorderThickness="{x:Bind UniformRowBorderThickness, Mode=OneWay}"
                    CornerRadius="4"
                    Visibility="{x:Bind IsGroupHeader, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="2*" MinWidth="100" />
                            <ColumnDefinition Width="*" MinWidth="72" />
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            MinWidth="72"
                            Padding="4,2"
                            VerticalAlignment="Center"
                            Background="#2ECC71"
                            CornerRadius="3"
                            Visibility="{x:Bind ShowBestBadge, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White"
                                loc:Loc.Key="oxco.bestBadge" />
                        </Border>
                        <TextBlock
                            Grid.Column="1"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{x:Bind ForegroundColor, Converter={StaticResource HexToBrush}, Mode=OneTime}"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{x:Bind Name}" />
                        <TextBlock
                            Grid.Column="2"
                            FontFamily="Consolas"
                            FontSize="11"
                            Foreground="{x:Bind ForegroundColor, Converter={StaticResource HexToBrush}, Mode=OneTime}"
                            Opacity="0.85"
                            Text="{x:Bind Rel}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="3" FontFamily="Consolas" FontSize="11" Foreground="{x:Bind ForegroundColor, Converter={StaticResource HexToBrush}, Mode=OneTime}" Text="{x:Bind Duration}" />
                        <TextBlock Grid.Column="4" FontFamily="Consolas" FontSize="11" Foreground="{x:Bind ForegroundColor, Converter={StaticResource HexToBrush}, Mode=OneTime}" Text="{x:Bind Resolution}" />
                        <TextBlock Grid.Column="5" FontFamily="Consolas" FontSize="11" Foreground="{x:Bind ForegroundColor, Converter={StaticResource HexToBrush}, Mode=OneTime}" Text="{x:Bind Size}" />
                    </Grid>
                </Border>
            </StackPanel>
        </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <TabView HorizontalAlignment="Left" IsAddTabButtonVisible="False" MaxWidth="1200" TabWidthMode="Equal" VerticalAlignment="Top">
        <TabViewItem loc:Loc.HeaderKey="oxco.workflowTab" IsClosable="False">
            <ScrollViewer HorizontalContentAlignment="Left" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="16,12" HorizontalAlignment="Left" Spacing="10">
                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.originalFile" Text="{x:Bind ViewModel.SourcePath, Mode=TwoWay}" drop:VideoDrop.IsEnabled="True" drop:VideoDrop.PathPropertyName="SourcePath" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickSourceCommand}" loc:Loc.Key="common.addDots" />
                                <TextBox Grid.Column="2" loc:Loc.HeaderKey="oxco.deepfakeFile" Text="{x:Bind ViewModel.DeepfakePath, Mode=TwoWay}" drop:VideoDrop.IsEnabled="True" drop:VideoDrop.PathPropertyName="DeepfakePath" />
                                <Button Grid.Column="3" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickDeepfakeCommand}" loc:Loc.Key="common.addDots" />
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.originalFolder" Text="{x:Bind ViewModel.CompareSourceDir, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickCompareSourceDirCommand}" loc:Loc.Key="common.addDots" />
                                <TextBox Grid.Column="2" loc:Loc.HeaderKey="oxco.deepfakeFolder" Text="{x:Bind ViewModel.CompareDeepfakeDir, Mode=TwoWay}" />
                                <Button Grid.Column="3" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickCompareDeepfakeDirCommand}" loc:Loc.Key="common.addDots" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox loc:Loc.Key="common.recursive" IsChecked="{x:Bind ViewModel.CompareRecursive, Mode=TwoWay}" VerticalAlignment="Center" />
                                <Button Command="{x:Bind ViewModel.LoadCompareListsCommand}" loc:Loc.Key="oxco.loadLists" />
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="common.sort" />
                                <ComboBox
                                    MinWidth="180"
                                    ItemsSource="{x:Bind ViewModel.CompareSortChoices, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.CompareSortLabel, Mode=TwoWay}" />
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="common.group" />
                                <ComboBox
                                    MinWidth="160"
                                    ItemsSource="{x:Bind ViewModel.CompareGroupChoices, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.CompareGroupLabel, Mode=TwoWay}" />
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.ProbeStatus, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ToolShellCard}">
                            <Grid RowSpacing="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="oxco.originalSelect" />
                                <Grid Grid.Row="1" Padding="6,4,6,2" ColumnSpacing="8" Opacity="0.75">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" MinWidth="100" />
                                        <ColumnDefinition Width="*" MinWidth="72" />
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.name" />
                                    <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.path" />
                                    <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.length" />
                                    <TextBlock Grid.Column="3" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.resolution" />
                                    <TextBlock Grid.Column="4" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.size" />
                                </Grid>
                                <Border
                                    Grid.Row="2"
                                    MaxHeight="300"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <ListView
                                        x:Name="OriginalList"
                                        MaxHeight="298"
                                        ItemContainerStyle="{StaticResource OxcoCompareListItemStyle}"
                                        ItemTemplate="{StaticResource OxcoCompareRowTemplate}"
                                        ItemsSource="{x:Bind ViewModel.OriginalDisplayItems, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedOriginalItem, Mode=TwoWay}"
                                        SelectionChanged="OriginalList_OnSelectionChanged"
                                        SelectionMode="Single"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource ToolShellCard}">
                            <Grid RowSpacing="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="oxco.deepfakeMultiSelect" />
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Padding="0,0,0,4">
                                    <Button
                                        Click="MoveSelectedDeepfakesToBitrate_Click"
                                        Content="{x:Bind ViewModel.MoveSelectedDeepfakesToBitrateLabel, Mode=OneWay}" />
                                    <Button
                                        Click="MoveSelectedDeepfakesToTagger_Click"
                                        Content="{x:Bind ViewModel.MoveSelectedDeepfakesToTaggerLabel, Mode=OneWay}" />
                                </StackPanel>
                                <Grid Grid.Row="2" Padding="6,4,6,2" ColumnSpacing="8" Opacity="0.75">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="2*" MinWidth="100" />
                                        <ColumnDefinition Width="*" MinWidth="72" />
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Width="72" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="oxco.colMark" />
                                    <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.name" />
                                    <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.path" />
                                    <TextBlock Grid.Column="3" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.length" />
                                    <TextBlock Grid.Column="4" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.resolution" />
                                    <TextBlock Grid.Column="5" FontSize="11" FontWeight="SemiBold" loc:Loc.Key="common.size" />
                                </Grid>
                                <Border
                                    Grid.Row="3"
                                    MaxHeight="300"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <ListView
                                        x:Name="DeepfakeList"
                                        MaxHeight="298"
                                        IsRightTapEnabled="True"
                                        ItemContainerStyle="{StaticResource OxcoCompareDeepfakeListItemStyle}"
                                        ItemTemplate="{StaticResource OxcoCompareRowTemplate}"
                                        ItemsSource="{x:Bind ViewModel.DeepfakeDisplayItems, Mode=OneWay}"
                                        SelectionChanged="DeepfakeList_OnSelectionChanged"
                                        SelectionMode="Extended"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                loc:Loc.Key="oxco.colorLegend"
                                TextWrapping="WrapWholeWords" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Border Width="14" Height="14" BorderBrush="#0078D4" BorderThickness="3" CornerRadius="2" />
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="oxco.legendMarkedSelected" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Border Width="14" Height="14" Background="#fff3b0" CornerRadius="2" />
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="oxco.legendMatch" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Border Width="14" Height="14" Background="#2ECC71" CornerRadius="2" />
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="oxco.legendBest" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{x:Bind ViewModel.UseSessionInputCommand}" loc:Loc.Key="oxco.sessionInput" />
                                <Button Command="{x:Bind ViewModel.RunCompareCommand}" loc:Loc.Key="common.startCompare" Style="{StaticResource AccentButtonStyle}" />
                                <Button Command="{x:Bind ViewModel.RunCompareBatchCommand}" loc:Loc.Key="oxco.batchSelection" />
                                <Button Command="{x:Bind ViewModel.StopCompareCommand}" loc:Loc.Key="common.stopButton" />
                                <Button Command="{x:Bind ViewModel.RetryCompareCommand}" loc:Loc.Key="oxco.repeatExport" IsEnabled="{x:Bind ViewModel.CanRetryCompare, Mode=OneWay}" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="oxco.deepfakeListHint" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="oxco.step2Bitrate" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{x:Bind ViewModel.BitrateScanCommand}" loc:Loc.Key="common.scan" />
                                <Button Command="{x:Bind ViewModel.BitrateConvertCommand}" loc:Loc.Key="common.convert" />
                                <Button Command="{x:Bind ViewModel.MoveBitrateRowsToTaggerCommand}" loc:Loc.Key="oxco.moveConvertedToTagger" />
                            </StackPanel>
                            <ListView
                                MaxHeight="160"
                                ItemsSource="{x:Bind ViewModel.BitrateRows, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:BitrateRowViewModel">
                                        <Grid Padding="4,2" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="72" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Path}" />
                                            <TextBlock Grid.Column="1" FontFamily="Consolas" FontSize="11" Text="{x:Bind Resolution}" />
                                            <TextBlock Grid.Column="2" FontFamily="Consolas" FontSize="11" Text="{x:Bind SourceKbps}" />
                                            <TextBlock Grid.Column="3" FontFamily="Consolas" FontSize="11" Text="{x:Bind TargetKbps}" />
                                            <TextBlock Grid.Column="4" FontFamily="Consolas" FontSize="11" Text="{x:Bind EstSaveMb}" />
                                            <TextBlock Grid.Column="5" FontFamily="Consolas" FontSize="11" Text="{x:Bind Action}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="oxco.step3Autotagger" />
                            <Grid x:Name="TaggerSectionGrid" ColumnSpacing="8" MinHeight="320">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.25*" MinWidth="200" />
                                    <ColumnDefinition Width="*" MinWidth="320" MaxWidth="560" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" MinHeight="120" MaxHeight="360" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                        <StackPanel MinWidth="200" Spacing="4">
                                            <ComboBox
                                                x:Name="TaggerTagBox"
                                                loc:Loc.HeaderKey="oxco.tagInFilename"
                                                IsEditable="True"
                                                ItemsSource="{x:Bind ViewModel.TaggerTagChoices, Mode=OneWay}"
                                                loc:Loc.PlaceholderKey="oxco.tagPlaceholder"
                                                Text="{x:Bind ViewModel.TaggerTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock
                                                Opacity="0.75"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                loc:Loc.Key="oxco.tagHintFull"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <TextBox MinWidth="100" loc:Loc.HeaderKey="common.profile" Text="{x:Bind ViewModel.TaggerProfileName, Mode=TwoWay}" />
                                        <Button VerticalAlignment="Bottom" Command="{x:Bind ViewModel.RefreshTaggerListCommand}" loc:Loc.Key="oxco.loadList" />
                                    </StackPanel>
                                    <ListView
                                        x:Name="TaggerList"
                                        Grid.Row="1"
                                        ItemsSource="{x:Bind ViewModel.TaggerFiles, Mode=OneWay}"
                                        SelectionChanged="TaggerList_OnSelectionChanged"
                                        SelectionMode="Extended">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="viewModels:TaggerFileRowViewModel">
                                                <TextBlock Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Path}" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                                <Grid Grid.Column="1" RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="oxco.previewRecognize" TextWrapping="WrapWholeWords" />
                                    <controls:AspectFitImagePresenter
                                        Grid.Row="1"
                                        MaxPreviewHeight="480"
                                        MinPreviewHeight="120"
                                        ImageSource="{x:Bind ViewModel.TaggerPreviewImage, Mode=OneWay}" />
                                    <Slider
                                        Grid.Row="2"
                                        IsEnabled="{x:Bind ViewModel.TaggerPreviewIsLoaded, Mode=OneWay}"
                                        Maximum="{x:Bind ViewModel.TaggerPreviewFrameMax, Mode=OneWay}"
                                        Value="{x:Bind ViewModel.TaggerPreviewFrameIndex, Mode=TwoWay}" />
                                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6">
                                        <Button Command="{x:Bind ViewModel.ToggleTaggerPreviewPlayCommand}" Content="{x:Bind ViewModel.TaggerPreviewPlayText, Mode=OneWay}" />
                                        <Button Command="{x:Bind ViewModel.TaggerPreviewStepBackCommand}" Content="◀" />
                                        <Button Command="{x:Bind ViewModel.TaggerPreviewStepForwardCommand}" Content="▶" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="4" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.TaggerPreviewInfo, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                </Grid>
                            </Grid>
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="oxco.scopeHintFull" TextWrapping="WrapWholeWords" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="RunTaggerAll_Click" loc:Loc.Key="oxco.processAllFiles" />
                                <Button Click="RunTaggerSelected_Click" loc:Loc.Key="oxco.processSelection" />
                                <Button Click="TagRouteSetup_Click" loc:Loc.Key="oxco.tagRouteSetup" />
                                <CheckBox loc:Loc.Key="oxco.autoAfterTag" IsChecked="{x:Bind ViewModel.TaggerRouteAuto, Mode=TwoWay}" VerticalAlignment="Center" />
                                <Button Command="{x:Bind ViewModel.DistributeByTagRouteCommand}" loc:Loc.Key="common.distribute" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.Status, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabViewItem>

        <TabViewItem loc:Loc.HeaderKey="common.paths" IsClosable="False">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="16,12" MaxWidth="720" Spacing="10">
                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.paths" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="oxco.pathsChainHint" TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.compareExport" Text="{x:Bind ViewModel.CompareExportDir, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickExportDirCommand}" loc:Loc.Key="common.addDots" />
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.bitrateInput" Text="{x:Bind ViewModel.BitrateInDir, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickBitrateInDirCommand}" loc:Loc.Key="common.addDots" />
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.bitrateOutput" Text="{x:Bind ViewModel.BitrateOutDir, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickBitrateOutDirCommand}" loc:Loc.Key="common.addDots" />
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.taggerInput" Text="{x:Bind ViewModel.TaggerInDir, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickTaggerInDirCommand}" loc:Loc.Key="common.addDots" />
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.taggerOutput" Text="{x:Bind ViewModel.TaggerOutDir, Mode=TwoWay}" />
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickTaggerOutDirCommand}" loc:Loc.Key="common.addDots" />
                            </Grid>
                            <TextBox loc:Loc.HeaderKey="oxco.filenamePattern" Text="{x:Bind ViewModel.TaggerPattern, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabViewItem>

        <TabViewItem loc:Loc.HeaderKey="oxco.filterTab" IsClosable="False">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="16,12" MaxWidth="720" Spacing="10">
                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="oxco.filterCompareSection" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.bufferSeconds" Text="{x:Bind ViewModel.FilterBuffer, Mode=TwoWay}" />
                                <TextBox Grid.Column="1" loc:Loc.HeaderKey="oxco.noise" Text="{x:Bind ViewModel.FilterNoise, Mode=TwoWay}" />
                                <TextBox Grid.Column="2" loc:Loc.HeaderKey="oxco.pixelThreshold" Text="{x:Bind ViewModel.FilterPixel, Mode=TwoWay}" />
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" loc:Loc.HeaderKey="oxco.pixelMaxOff" Text="{x:Bind ViewModel.FilterPixelMax, Mode=TwoWay}" />
                                <TextBox Grid.Column="1" loc:Loc.HeaderKey="oxco.davinciTimeout" Text="{x:Bind ViewModel.FilterDavinciTimeout, Mode=TwoWay}" />
                            </Grid>
                            <CheckBox loc:Loc.Key="oxco.ffmpegExport" IsChecked="{x:Bind ViewModel.FilterFfmpeg, Mode=TwoWay}" />
                            <CheckBox loc:Loc.Key="oxco.davinciExport" IsChecked="{x:Bind ViewModel.FilterDavinci, Mode=TwoWay}" />
                            <CheckBox
                                loc:Loc.Key="oxco.batchPipeline"
                                IsChecked="{x:Bind ViewModel.CompareBatchPipeline, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.FilterDavinci, Mode=OneWay}"
                                loc:Loc.ToolTipKey="oxco.batchPipelineTooltip" />
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                loc:Loc.Key="oxco.pipelineOffHint"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                loc:Loc.Key="oxco.davinciOnlyHint"
                                TextWrapping="WrapWholeWords" />
                            <ComboBox loc:Loc.HeaderKey="oxco.ffmpegTargetHeader" ItemsSource="{x:Bind ViewModel.TargetChoices, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.FilterFfmpegTarget, Mode=TwoWay}" />
                            <CheckBox loc:Loc.Key="oxco.exportUniqueName" IsChecked="{x:Bind ViewModel.FilterExportUnique, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.bitrate" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ComboBox Width="200" loc:Loc.HeaderKey="common.preset" ItemsSource="{x:Bind ViewModel.BrPresetOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.BrPreset, Mode=TwoWay}" />
                                <Button VerticalAlignment="Bottom" Command="{x:Bind ViewModel.ApplyBrPresetCommand}" loc:Loc.Key="oxco.applyPreset" />
                            </StackPanel>
                            <Grid ColumnSpacing="8" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0" Grid.Column="0" loc:Loc.HeaderKey="oxco.brMin2160" Text="{x:Bind ViewModel.BrRule2160, Mode=TwoWay}" />
                                <TextBox Grid.Row="0" Grid.Column="1" loc:Loc.HeaderKey="oxco.brMin1440" Text="{x:Bind ViewModel.BrRule1440, Mode=TwoWay}" />
                                <TextBox Grid.Row="0" Grid.Column="2" loc:Loc.HeaderKey="oxco.brMin1080" Text="{x:Bind ViewModel.BrRule1080, Mode=TwoWay}" />
                                <TextBox Grid.Row="1" Grid.Column="0" loc:Loc.HeaderKey="oxco.brMin720" Text="{x:Bind ViewModel.BrRule720, Mode=TwoWay}" />
                                <TextBox Grid.Row="1" Grid.Column="1" loc:Loc.HeaderKey="oxco.brMin480" Text="{x:Bind ViewModel.BrRule480, Mode=TwoWay}" />
                                <TextBox Grid.Row="1" Grid.Column="2" loc:Loc.HeaderKey="oxco.brMin360" Text="{x:Bind ViewModel.BrRule360, Mode=TwoWay}" />
                                <TextBox Grid.Row="2" Grid.Column="0" loc:Loc.HeaderKey="oxco.brMin0" Text="{x:Bind ViewModel.BrRule0, Mode=TwoWay}" />
                            </Grid>
                            <CheckBox loc:Loc.Key="oxco.includeSubfoldersBitrate" IsChecked="{x:Bind ViewModel.BrRecursive, Mode=TwoWay}" />
                            <CheckBox loc:Loc.Key="oxco.onlyLowerNever" IsChecked="{x:Bind ViewModel.BrOnlyLower, Mode=TwoWay}" />
                            <TextBox loc:Loc.HeaderKey="oxco.outputSuffix" Text="{x:Bind ViewModel.BrSuffix, Mode=TwoWay}" />
                            <CheckBox loc:Loc.Key="oxco.outputAsMp4" IsChecked="{x:Bind ViewModel.BrOutputMp4, Mode=TwoWay}" />
                            <CheckBox loc:Loc.Key="oxco.deleteOriginalAfterOk" IsChecked="{x:Bind ViewModel.BrDeleteSourceAfterOk, Mode=TwoWay}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" loc:Loc.HeaderKey="common.codec" ItemsSource="{x:Bind ViewModel.BrCodecOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.BrCodec, Mode=TwoWay}" />
                                <ComboBox Grid.Column="1" loc:Loc.HeaderKey="oxco.audioHeader" ItemsSource="{x:Bind ViewModel.BrAudioOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.BrAudio, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="oxco.autotaggerPatternsSection" />
                            <TextBox loc:Loc.HeaderKey="oxco.filenamePatternHeader" Text="{x:Bind ViewModel.TaggerPattern, Mode=TwoWay}" />
                            <TextBox loc:Loc.HeaderKey="oxco.keepSuffixesCsv" Text="{x:Bind ViewModel.TaggerKeep, Mode=TwoWay}" />
                            <TextBox loc:Loc.HeaderKey="oxco.ignoreSuffixesCsv" Text="{x:Bind ViewModel.TaggerIgnore, Mode=TwoWay}" />
                            <TextBox loc:Loc.HeaderKey="oxco.dropSuffixesCsv" Text="{x:Bind ViewModel.TaggerDrop, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ToolShellCard}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="oxco.davinciResolveSection" />
                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                loc:Loc.Key="oxco.davinciApiHint"
                                TextWrapping="WrapWholeWords" />
                            <TextBox loc:Loc.HeaderKey="texttovideo.renderPreset" Text="{x:Bind ViewModel.DavinciRenderPreset, Mode=TwoWay}" />
                            <TextBox loc:Loc.HeaderKey="oxco.startupWait" Text="{x:Bind ViewModel.DavinciStartupWaitSeconds, Mode=TwoWay}" />
                            <Button Command="{x:Bind ViewModel.SaveSettingsCommand}" loc:Loc.Key="oxco.saveFilters" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabViewItem>

        <TabViewItem loc:Loc.HeaderKey="common.preview" IsClosable="False">
            <controls:OxcoComparePreviewHost x:Name="PreviewHost" ViewModel="{x:Bind ViewModel, Mode=OneWay}" />
        </TabViewItem>
    </TabView>
</UserControl>

<?xml version="1.0" encoding="utf-8" ?>

<UserControl

    x:Class="HailMary.Views.StashCutterPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    HorizontalAlignment="Left"

    VerticalAlignment="Top"

    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">



    <Grid HorizontalAlignment="Left" MaxWidth="960" Padding="16,12" ColumnSpacing="10" VerticalAlignment="Top">

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="*" MinWidth="300" />

            <ColumnDefinition Width="1.4*" MinWidth="380" />

        </Grid.ColumnDefinitions>



        <!-- Stash -->

        <Border Grid.Column="0" Style="{StaticResource ToolShellCard}" VerticalAlignment="Stretch">

            <StackPanel Spacing="10">

                <StackPanel Spacing="2">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="stashcutter.stashSceneHeader" />

                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.ConnectionInfo, Mode=OneWay}" />

                </StackPanel>

                <Grid ColumnSpacing="8">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*" />

                        <ColumnDefinition Width="Auto" />

                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" loc:Loc.HeaderKey="common.searchScene" KeyDown="SearchBox_OnKeyDown" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />

                    <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.SearchCommand}" loc:Loc.Key="common.search" />

                </Grid>

                <Grid ColumnSpacing="8">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*" />

                        <ColumnDefinition Width="Auto" />

                        <ColumnDefinition Width="Auto" />

                        <ColumnDefinition Width="Auto" />

                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" loc:Loc.HeaderKey="common.sceneId" KeyDown="SceneIdBox_OnKeyDown" Text="{x:Bind ViewModel.SceneId, Mode=TwoWay}" />

                    <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.LoadSceneCommand}" loc:Loc.Key="common.load" />

                    <Button

                        Grid.Column="2"

                        VerticalAlignment="Bottom"

                        Command="{x:Bind ViewModel.LoadFromSessionCommand}"

                        loc:Loc.Key="common.lastScene"

                        loc:Loc.ToolTipKey="stash.lastSceneTooltip" />

                    <Button Grid.Column="3" VerticalAlignment="Bottom" Click="ClipboardButton_Click" loc:Loc.Key="common.clipboard" />

                </Grid>

                <StackPanel Spacing="4">

                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="stash.resultsHint" />

                    <ListView

                        x:Name="ResultsList"

                        MinHeight="120"

                        DoubleTapped="ResultsList_OnDoubleTapped"

                        ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"

                        ScrollViewer.VerticalScrollBarVisibility="Disabled"

                        ScrollViewer.VerticalScrollMode="Disabled"

                        SelectionChanged="ResultsList_OnSelectionChanged">

                        <ListView.ItemTemplate>

                            <DataTemplate x:DataType="viewModels:StashSceneRowViewModel" xmlns:viewModels="using:HailMary.ViewModels">

                                <TextBlock FontFamily="Consolas" Text="{x:Bind Display}" TextTrimming="CharacterEllipsis" />

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">

                    <TextBlock

                        VerticalAlignment="Center"

                        FontFamily="Consolas"

                        Text="{x:Bind ViewModel.LoadedSummary, Mode=OneWay}"

                        TextTrimming="CharacterEllipsis"

                        TextWrapping="WrapWholeWords" />

                    <Button Command="{x:Bind ViewModel.OpenInStashCommand}" loc:Loc.Key="common.inStash" />

                </StackPanel>

            </StackPanel>

        </Border>



        <!-- Schnitt: gleicher Aufbau wie SceneCutterPanel (Video-Vorschau oben in der Shell) -->

        <Border Grid.Column="1" Style="{StaticResource ToolShellCard}" VerticalAlignment="Stretch">

            <Grid RowSpacing="10">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="Auto" />

                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="2">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="stashcutter.cutHeader" />

                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" loc:Loc.Key="stashcutter.cutHint" TextWrapping="WrapWholeWords" />

                </StackPanel>

                <ContentControl

                    x:Name="CutterContentHost"

                    Grid.Row="1"

                    HorizontalAlignment="Stretch"

                    VerticalAlignment="Top"

                    HorizontalContentAlignment="Stretch"

                    VerticalContentAlignment="Stretch" />

            </Grid>

        </Border>

    </Grid>

</UserControl>



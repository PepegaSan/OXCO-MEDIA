<?xml version="1.0" encoding="utf-8" ?>

<UserControl

    x:Class="HailMary.Views.BitrateChangerPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">



    <ScrollViewer HorizontalContentAlignment="Left" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

        <StackPanel Style="{StaticResource ToolShellContentPanel}" Spacing="10">

            <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" TextWrapping="WrapWholeWords" />

            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.Status, Mode=OneWay}" />



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="autotagger.foldersHeader" />

                    <Grid ColumnSpacing="8" RowSpacing="8">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="120" />

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition />

                            <RowDefinition />

                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="audiocleaner.inputHeader" />

                        <TextBox Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.InputFolder, Mode=TwoWay}" />

                        <Button Grid.Row="0" Grid.Column="2" Command="{x:Bind ViewModel.PickInputFolderCommand}" loc:Loc.Key="common.addDots" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="bitrate.outputLabel" />

                        <TextBox Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.OutputFolder, Mode=TwoWay}" />

                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Spacing="4">

                            <Button Command="{x:Bind ViewModel.PickOutputFolderCommand}" loc:Loc.Key="common.addDots" />

                            <Button Command="{x:Bind ViewModel.AutoOutputCommand}" loc:Loc.Key="common.auto" />

                        </StackPanel>

                    </Grid>

                    <CheckBox loc:Loc.Key="bitrate.outputBesideSource" IsChecked="{x:Bind ViewModel.OutputBesideSource, Mode=TwoWay}" />

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="bitrate.renameHeader" />

                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        loc:Loc.Key="bitrate.renameHint"
                        TextWrapping="WrapWholeWords" />

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <Button Command="{x:Bind ViewModel.PreviewRenamesCommand}" loc:Loc.Key="common.preview" />

                        <Button Command="{x:Bind ViewModel.StripSuffixNowCommand}" loc:Loc.Key="bitrate.stripSuffixNow" />

                    </StackPanel>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="bitrate.optionsHeader" />

                    <Grid ColumnSpacing="12" RowSpacing="8">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="*" />

                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">

                            <CheckBox loc:Loc.Key="common.recursive" IsChecked="{x:Bind ViewModel.Recursive, Mode=TwoWay}" />

                            <CheckBox loc:Loc.Key="bitrate.onlyLower" IsChecked="{x:Bind ViewModel.OnlyLower, Mode=TwoWay}" />

                            <CheckBox loc:Loc.Key="bitrate.outputMp4" IsChecked="{x:Bind ViewModel.OutputMp4, Mode=TwoWay}" />

                            <CheckBox loc:Loc.Key="bitrate.stripAfterSuccess" IsChecked="{x:Bind ViewModel.StripAutobitrateSuffix, Mode=TwoWay}" />

                            <TextBlock
                                Style="{StaticResource CaptionTextBlockStyle}"
                                loc:Loc.Key="bitrate.replaceOriginalHint"
                                TextWrapping="WrapWholeWords" />

                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">

                            <ComboBox loc:Loc.HeaderKey="audiocleaner.videoCodec" ItemsSource="{x:Bind ViewModel.CodecOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedCodec, Mode=TwoWay}" />

                            <ComboBox loc:Loc.HeaderKey="oxco.audioHeader" ItemsSource="{x:Bind ViewModel.AudioModeOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedAudioMode, Mode=TwoWay}" />

                            <ComboBox Header="Nach Erfolg" ItemsSource="{x:Bind ViewModel.PostActionOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedPostAction, Mode=TwoWay}" />

                            <TextBox loc:Loc.HeaderKey="common.suffix" Text="{x:Bind ViewModel.Suffix, Mode=TwoWay}" />

                        </StackPanel>

                    </Grid>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="bitrate.rulesHeader" />

                    <Grid ColumnSpacing="8" RowSpacing="4">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="*" />

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition /><RowDefinition />

                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0" Header="2160p" Text="{x:Bind ViewModel.Rule2160, Mode=TwoWay}" />

                        <TextBox Grid.Row="0" Grid.Column="1" Header="1440p" Text="{x:Bind ViewModel.Rule1440, Mode=TwoWay}" />

                        <TextBox Grid.Row="0" Grid.Column="2" Header="1080p" Text="{x:Bind ViewModel.Rule1080, Mode=TwoWay}" />

                        <TextBox Grid.Row="0" Grid.Column="3" Header="720p" Text="{x:Bind ViewModel.Rule720, Mode=TwoWay}" />

                        <TextBox Grid.Row="1" Grid.Column="0" Header="480p" Text="{x:Bind ViewModel.Rule480, Mode=TwoWay}" />

                        <TextBox Grid.Row="1" Grid.Column="1" Header="360p" Text="{x:Bind ViewModel.Rule360, Mode=TwoWay}" />

                        <TextBox Grid.Row="1" Grid.Column="2" Header="&lt;360p" Text="{x:Bind ViewModel.Rule0, Mode=TwoWay}" />

                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <ComboBox Width="180" ItemsSource="{x:Bind ViewModel.PresetOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}" />

                        <Button Command="{x:Bind ViewModel.LoadPresetCommand}" loc:Loc.Key="bitrate.loadPreset" />

                    </StackPanel>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <Button Command="{x:Bind ViewModel.ScanCommand}" loc:Loc.Key="bitrate.scanFolder" />

                        <Button Command="{x:Bind ViewModel.MarkAllRowsCommand}" loc:Loc.Key="common.markAll" />

                        <Button Command="{x:Bind ViewModel.UnmarkAllRowsCommand}" loc:Loc.Key="common.unmarkAll" />

                    </StackPanel>

                    <TextBlock

                        Style="{StaticResource CaptionTextBlockStyle}"

                        loc:Loc.Key="bitrate.scanHintFull" />

                    <ListView MinHeight="220" ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}" SelectionMode="Extended">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.Header>
                            <Grid Padding="4,0,4,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="✓" />

                                <TextBlock Grid.Column="1" FontWeight="SemiBold" loc:Loc.Key="bitrate.colFile" />

                                <TextBlock Grid.Column="2" FontWeight="SemiBold" loc:Loc.Key="bitrate.colResolution" />

                                <TextBlock Grid.Column="3" FontWeight="SemiBold" loc:Loc.Key="bitrate.colSource" />

                                <TextBlock Grid.Column="4" FontWeight="SemiBold" loc:Loc.Key="bitrate.colTarget" />

                                <Button
                                    Grid.Column="5"
                                    Padding="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{x:Bind ViewModel.SortRowsBySaveMbCommand, Mode=OneWay}"
                                    FontWeight="SemiBold"
                                    loc:Loc.Key="bitrate.colSaveMb" />

                                <TextBlock Grid.Column="6" FontWeight="SemiBold" loc:Loc.Key="bitrate.colAction" />

                                <TextBlock Grid.Column="7" FontWeight="SemiBold" loc:Loc.Key="bitrate.colReason" />
                            </Grid>
                        </ListView.Header>

                        <ListView.ItemTemplate>

                            <DataTemplate x:DataType="viewmodels:BitrateRowViewModel" xmlns:viewmodels="using:HailMary.ViewModels">

                                <Grid Padding="4,0" ColumnSpacing="8">

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="36" />

                                        <ColumnDefinition Width="200" />

                                        <ColumnDefinition Width="88" />

                                        <ColumnDefinition Width="56" />

                                        <ColumnDefinition Width="48" />

                                        <ColumnDefinition Width="56" />

                                        <ColumnDefinition Width="72" />

                                        <ColumnDefinition Width="120" />

                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{x:Bind IsIncluded, Mode=TwoWay}" />

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind FileName}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap"
                                        ToolTipService.ToolTip="{x:Bind Path}" />

                                    <TextBlock Grid.Column="2" Text="{x:Bind Resolution}" TextWrapping="NoWrap" />

                                    <TextBlock Grid.Column="3" Text="{x:Bind SourceKbps}" TextWrapping="NoWrap" />

                                    <TextBlock Grid.Column="4" Text="{x:Bind TargetKbps}" TextWrapping="NoWrap" />

                                    <TextBlock Grid.Column="5" Text="{x:Bind EstSaveMb}" TextWrapping="NoWrap" />

                                    <TextBlock Grid.Column="6" Text="{x:Bind Action}" TextWrapping="NoWrap" />

                                    <TextBlock
                                        Grid.Column="7"
                                        Text="{x:Bind Reason}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap"
                                        ToolTipService.ToolTip="{x:Bind Reason}" />

                                </Grid>

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                </StackPanel>

            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>



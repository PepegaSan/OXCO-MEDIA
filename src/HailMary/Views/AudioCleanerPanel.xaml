<?xml version="1.0" encoding="utf-8" ?>

<UserControl

    x:Class="HailMary.Views.AudioCleanerPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    xmlns:drop="using:HailMary.Views.Helpers"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">

    <ScrollViewer HorizontalContentAlignment="Left" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{StaticResource ToolShellContentPanel}" Spacing="10">

            <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" TextWrapping="WrapWholeWords" />

            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.Status, Mode=OneWay}" />



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="audiocleaner.inputHeader" />

                    <Grid ColumnSpacing="8" drop:VideoDrop.AllowFolders="True" drop:VideoDrop.IsEnabled="True">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" loc:Loc.PlaceholderKey="audiocleaner.inputPlaceholder" Text="{x:Bind ViewModel.InputPath, Mode=TwoWay}" />

                        <Button Grid.Column="1" VerticalAlignment="Center" Command="{x:Bind ViewModel.PickInputFileCommand}" loc:Loc.Key="common.file" />

                        <Button Grid.Column="2" VerticalAlignment="Center" Command="{x:Bind ViewModel.PickInputFolderCommand}" loc:Loc.Key="common.folder" />

                    </Grid>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="audiocleaner.filesHeader" />

                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.BatchSummary, Mode=OneWay}" />

                    <ListView

                        MaxHeight="100"

                        ItemsSource="{x:Bind ViewModel.BatchFiles, Mode=OneWay}"

                        SelectionMode="None">

                        <ListView.ItemTemplate>

                            <DataTemplate x:DataType="x:String">

                                <TextBlock FontFamily="Consolas" Text="{x:Bind}" TextTrimming="CharacterEllipsis" />

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                    <Grid ColumnSpacing="8">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="audiocleaner.outputDirHeader" Text="{x:Bind ViewModel.OutputDir, Mode=TwoWay}" />

                        <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickOutputDirCommand}" loc:Loc.Key="common.addDots" />

                    </Grid>

                    <TextBox loc:Loc.HeaderKey="audiocleaner.outputPreview" IsReadOnly="True" Text="{x:Bind ViewModel.OutputPath, Mode=OneWay}" />

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="audiocleaner.cleanHeader" />

                    <ComboBox loc:Loc.HeaderKey="common.preset" ItemsSource="{x:Bind ViewModel.PresetOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}" />

                    <CheckBox loc:Loc.Key="audiocleaner.focusEcho" IsChecked="{x:Bind ViewModel.FocusEcho, Mode=TwoWay}" />

                    <CheckBox loc:Loc.Key="audiocleaner.focusNoise" IsChecked="{x:Bind ViewModel.FocusNoise, Mode=TwoWay}" />

                    <TextBox loc:Loc.HeaderKey="audiocleaner.boostHeader" Text="{x:Bind ViewModel.BoostPercent, Mode=TwoWay}" />

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="audiocleaner.videoSection" />

                    <ComboBox loc:Loc.HeaderKey="audiocleaner.videoCodec" ItemsSource="{x:Bind ViewModel.VideoCodecOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedVideoCodec, Mode=TwoWay}" />

                    <TextBox loc:Loc.HeaderKey="audiocleaner.videoBitrate" Text="{x:Bind ViewModel.VideoBitrateKbps, Mode=TwoWay}" />

                </StackPanel>

            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>



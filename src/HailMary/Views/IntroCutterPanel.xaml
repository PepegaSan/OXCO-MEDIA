<?xml version="1.0" encoding="utf-8" ?>

<UserControl

    x:Class="HailMary.Views.IntroCutterPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    xmlns:drop="using:HailMary.Views.Helpers"

    xmlns:models="using:HailMary.Models"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    mc:Ignorable="d" xmlns:loc="using:HailMary.Services">

    <ScrollViewer HorizontalContentAlignment="Left" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Style="{StaticResource ToolShellContentPanel}" Spacing="10">

            <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" TextWrapping="WrapWholeWords" />



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="audiocleaner.inputHeader" />

                    <Grid ColumnSpacing="8" drop:VideoDrop.AllowFolders="True" drop:VideoDrop.IsEnabled="True">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox

                            Grid.Column="0"

                            IsReadOnly="True"

                            loc:Loc.PlaceholderKey="intro.inputPlaceholder"

                            Text="{x:Bind ViewModel.PreviewVideoPath, Mode=OneWay}" />

                        <Button Grid.Column="1" VerticalAlignment="Center" Command="{x:Bind ViewModel.AddVideosCommand}" loc:Loc.Key="common.file" />

                        <Button Grid.Column="2" VerticalAlignment="Center" Command="{x:Bind ViewModel.AddFolderCommand}" loc:Loc.Key="common.folder" />

                    </Grid>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.batch" />

                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.BatchSummary, Mode=OneWay}" />

                    <TextBlock

                        Style="{StaticResource CaptionTextBlockStyle}"

                        loc:Loc.Key="intro.batchHint"

                        TextWrapping="WrapWholeWords" />

                    <ListView

                        x:Name="BatchList"

                        MaxHeight="180"

                        IsItemClickEnabled="True"

                        ItemClick="BatchList_OnItemClick"

                        ItemsSource="{x:Bind ViewModel.BatchFiles, Mode=OneWay}"

                        SelectionChanged="BatchList_OnSelectionChanged"

                        SelectionMode="Extended">

                        <ListView.ItemTemplate>

                            <DataTemplate x:DataType="models:IntroBatchEntry">

                                <Grid ColumnSpacing="8">

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="36" />

                                        <ColumnDefinition Width="*" />

                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{x:Bind IsIncluded, Mode=TwoWay}" />

                                    <TextBlock

                                        Grid.Column="1"

                                        FontFamily="Consolas"

                                        Text="{x:Bind FileName}"

                                        TextTrimming="CharacterEllipsis"

                                        ToolTipService.ToolTip="{x:Bind Path}" />

                                </Grid>

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <Button Command="{x:Bind ViewModel.MarkAllForCutCommand}" loc:Loc.Key="common.markAll" />

                        <Button Command="{x:Bind ViewModel.UnmarkAllForCutCommand}" loc:Loc.Key="common.unmarkAll" />

                        <Button Command="{x:Bind ViewModel.RemoveSelectedBatchCommand}" loc:Loc.Key="common.remove" />

                        <Button Command="{x:Bind ViewModel.ClearBatchCommand}" loc:Loc.Key="common.clearList" />

                    </StackPanel>

                    <CheckBox

                        loc:Loc.Key="intro.outputBesideSource"

                        IsChecked="{x:Bind ViewModel.OutputBesideSource, Mode=TwoWay}" />

                    <Grid ColumnSpacing="8" Visibility="{x:Bind ViewModel.ShowOutputDirField, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" loc:Loc.HeaderKey="audiocleaner.outputDirHeader" Text="{x:Bind ViewModel.OutputDir, Mode=TwoWay}" />

                        <Button Grid.Column="1" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.PickOutputDirCommand}" loc:Loc.Key="common.addDots" />

                    </Grid>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="intro.stripSuffixHeader" />

                    <TextBlock

                        Style="{StaticResource CaptionTextBlockStyle}"

                        Text="Entfernt _introcut (FFmpeg) bzw. _resolve_cut (DaVinci) aus Dateinamen im Ausgabe-Ordner bzw. neben den Quellen."

                        TextWrapping="WrapWholeWords" />

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <Button Command="{x:Bind ViewModel.PreviewStripSuffixCommand}" loc:Loc.Key="common.preview" />

                        <Button Command="{x:Bind ViewModel.ApplyStripSuffixCommand}" loc:Loc.Key="intro.stripSuffixHeader" />

                    </StackPanel>

                </StackPanel>

            </Border>



            <Border Style="{StaticResource ToolShellCard}">

                <StackPanel Spacing="8">

                    <TextBlock Style="{StaticResource ToolShellSectionHeader}" loc:Loc.Key="common.cut" />

                    <Grid ColumnSpacing="12">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="*" />

                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">

                            <TextBlock loc:Loc.Key="intro.introSec" />

                            <TextBox Text="{x:Bind ViewModel.IntroSec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">

                            <TextBlock loc:Loc.Key="intro.outroSec" />

                            <TextBox Text="{x:Bind ViewModel.OutroSec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        </StackPanel>

                    </Grid>

                    <Grid ColumnSpacing="8" RowSpacing="6">

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto" />

                            <RowDefinition Height="Auto" />

                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="8">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="Auto" />

                                <ColumnDefinition Width="*" />

                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="bitrate.loadPreset" />

                            <ComboBox Grid.Column="1" ItemsSource="{x:Bind ViewModel.LengthPresetNames, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedLengthPreset, Mode=TwoWay}" />

                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="8">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="Auto" />

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="Auto" />

                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" VerticalAlignment="Center" loc:Loc.Key="intro.presetNameLabel" />

                            <TextBox Grid.Column="1" Text="{x:Bind ViewModel.PresetNameToSave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Grid.Column="2" Command="{x:Bind ViewModel.SaveLengthPresetCommand}" loc:Loc.Key="common.save" />

                            <Button Grid.Column="3" Command="{x:Bind ViewModel.DeleteLengthPresetCommand}" loc:Loc.Key="common.delete" />

                        </Grid>

                    </Grid>

                    <CheckBox loc:Loc.Key="intro.useResolve" IsChecked="{x:Bind ViewModel.UseResolve, Mode=TwoWay}" />

                    <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.ShowFfmpegOptions, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

                        <ComboBox ItemsSource="{x:Bind ViewModel.VideoCodecOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedVideoCodec, Mode=TwoWay}" />

                        <TextBox Text="{x:Bind ViewModel.VideoBitrate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" loc:Loc.PlaceholderKey="intro.videoBitrate" Visibility="{x:Bind ViewModel.ShowVideoBitrateField, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                        <CheckBox loc:Loc.Key="intro.videoBitrateAuto" IsChecked="{x:Bind ViewModel.VideoBitrateAuto, Mode=TwoWay}" />

                        <Grid ColumnSpacing="12">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="*" />

                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" loc:Loc.HeaderKey="intro.audioCodec" Text="{x:Bind ViewModel.AudioCodec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBox Grid.Column="1" loc:Loc.HeaderKey="intro.audioBitrate" Text="{x:Bind ViewModel.AudioBitrate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        </Grid>

                    </StackPanel>

                    <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.UseResolve, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

                        <TextBlock loc:Loc.Key="intro.resolvePreset" />

                        <TextBox Text="{x:Bind ViewModel.RenderPreset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    </StackPanel>

                </StackPanel>

            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>



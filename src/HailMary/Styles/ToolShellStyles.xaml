<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Thickness x:Key="ToolShellContentPadding">16</Thickness>
    <x:Double x:Key="ToolShellContentMaxWidth">960</x:Double>
    <GridLength x:Key="ToolShellNavWidth">220</GridLength>
    <x:Double x:Key="ToolShellPreviewHeight">220</x:Double>

    <Style x:Key="ToolShellSectionHeader" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
        <Setter Property="FontFamily" Value="{StaticResource HmUiFont}" />
        <Setter Property="Margin" Value="0,8,0,4" />
    </Style>

    <Style x:Key="ToolShellContentPanel" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Padding" Value="{StaticResource ToolShellContentPadding}" />
        <Setter Property="MaxWidth" Value="{StaticResource ToolShellContentMaxWidth}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="ToolShellLeftContentPanel" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Padding" Value="16,12,16,16" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="MaxWidth" Value="720" />
    </Style>

    <Style x:Key="ToolShellPaneHeader" TargetType="Border">
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style x:Key="ToolShellPaneHeaderText" TargetType="TextBlock" BasedOn="{StaticResource SubtitleTextBlockStyle}" />

    <Style x:Key="ToolShellCard" TargetType="Border">
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{ThemeResource HmCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource HmCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

</ResourceDictionary>
